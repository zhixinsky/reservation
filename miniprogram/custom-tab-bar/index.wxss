.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  z-index: 10000;
  display: flex;
  flex-direction: row;
  justify-content: center;
  pointer-events: auto;
}

.tab-shell.hidden {
  display: none !important;
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
}

.tab-capsule {
  width: 420rpx;
  height: 84rpx;
  padding: 6rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: inset 0 0 0 1rpx rgba(222, 234, 226, 0.9), 0 14rpx 36rpx rgba(45, 67, 57, 0.14);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  width: 0;
  height: 72rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  color: #8B9A91;
  font-size: 25rpx;
  font-weight: 700;
}

.tab-item.active {
  background: rgba(232, 245, 233, 0.96);
  color: #2D6A4F;
}

.tab-text {
  line-height: 1;
}

/* 预约：日历图标 */
.tab-icon-book {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.book-hook {
  position: absolute;
  top: 1rpx;
  width: 4rpx;
  height: 9rpx;
  border-radius: 2rpx;
  background: #9CA8A0;
}

.book-hook-l {
  left: 8rpx;
}

.book-hook-r {
  right: 8rpx;
}

.book-panel {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  bottom: 0;
  top: 8rpx;
  border-radius: 8rpx;
  border: 3rpx solid #9CA8A0;
  box-sizing: border-box;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.5);
}

.book-header {
  height: 8rpx;
  background: #9CA8A0;
}

.book-dot-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding-top: 5rpx;
}

.book-dot {
  width: 5rpx;
  height: 5rpx;
  margin: 0 2rpx;
  border-radius: 50%;
  background: #9CA8A0;
}

.tab-item.active .book-hook,
.tab-item.active .book-header,
.tab-item.active .book-dot {
  background: #2D6A4F;
}

.tab-item.active .book-panel {
  border-color: #2D6A4F;
  background: rgba(232, 245, 233, 0.45);
}

/* 我的：用户图标 */
.tab-icon-user {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.user-head {
  position: absolute;
  top: 2rpx;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  margin-left: -7rpx;
  border-radius: 50%;
  border: 3rpx solid #9CA8A0;
  box-sizing: border-box;
  background: transparent;
}

.user-body {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  bottom: 1rpx;
  height: 14rpx;
  border: 3rpx solid #9CA8A0;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
  box-sizing: border-box;
  background: transparent;
}

.tab-item.active .user-head,
.tab-item.active .user-body {
  border-color: #2D6A4F;
}
