.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 28rpx;
  z-index: 9999;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.tab-capsule {
  width: 430rpx;
  height: 92rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(222, 234, 226, 0.9);
  box-shadow: 0 18rpx 46rpx rgba(45, 67, 57, 0.16);
  display: flex;
  align-items: center;
  justify-content: space-between;
  pointer-events: auto;
}

.tab-item {
  width: 200rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8B9A91;
  font-size: 27rpx;
  font-weight: 700;
}

.tab-item.active {
  background: rgba(232, 245, 233, 0.96);
  color: #2D6A4F;
}

.tab-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: transparent;
  margin-right: 10rpx;
}

.tab-item.active .tab-dot {
  background: #2D6A4F;
}

.tab-text {
  line-height: 1;
}
