.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 48rpx;
  z-index: 9999;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.tab-shell.hidden {
  display: none;
}

.tab-capsule {
  width: 398rpx;
  height: 80rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(222, 234, 226, 0.9);
  box-shadow: 0 14rpx 36rpx rgba(45, 67, 57, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  pointer-events: auto;
}

.tab-item {
  width: 188rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8B9A91;
  font-size: 25rpx;
  font-weight: 700;
}

.tab-item.active {
  background: rgba(232, 245, 233, 0.96);
  color: #2D6A4F;
}

.tab-icon {
  width: 34rpx;
  margin-right: 8rpx;
  font-size: 28rpx;
  line-height: 1;
  text-align: center;
  color: #9CA8A0;
}

.tab-item.active .tab-icon {
  color: #2D6A4F;
}

.tab-text {
  line-height: 1;
}
