page {
  min-height: 100vh;
  color: #2D4339;
  font-family: "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  background-color: #F9FBF9;
}

.font-display,
.title,
.btn-title,
.drawer-title,
.modal-title,
.brand-title,
.welcome-title,
.success-title {
  font-family: "Noto Serif SC", "PingFang SC", "Songti SC", serif;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  font-family: inherit;
}

button::after {
  border: 0;
}
