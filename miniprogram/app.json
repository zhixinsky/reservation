{
  "pages": [
    "pages/index/index",
    "pages/my/my",
    "pages/admin-dashboard/admin-dashboard"
  ],
  "window": {
    "navigationBarTitleText": "预约服务",
    "navigationBarBackgroundColor": "#F9FBF9",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#F9FBF9"
  },
  "tabBar": {
    "custom": true,
    "color": "#9ca3af",
    "selectedColor": "#2D6A4F",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "预约"
      },
      {
        "pagePath": "pages/my/my",
        "text": "我的"
      }
    ]
  },
  "style": "v2",
  "permission": {
    "scope.userLocation": {
      "desc": "用于为您推荐距离最近的门店"
    }
  },
  "requiredPrivateInfos": [
    "getLocation"
  ],
  "lazyCodeLoading": "requiredComponents",
  "rendererOptions": {
    "skyline": {
      "defaultDisplayBlock": true,
      "disableABTest": true
    }
  },
  "sitemapLocation": "sitemap.json",
  "subPackages": [
    {
      "root": "pkg/font400",
      "name": "font400",
      "pages": ["index/index"]
    },
    {
      "root": "pkg/font700",
      "name": "font700",
      "pages": ["index/index"]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["font400", "font700"]
    },
    "pages/my/my": {
      "network": "all",
      "packages": ["font400", "font700"]
    }
  }
}
