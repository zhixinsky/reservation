.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 20% 20%, rgba(127, 169, 152, 0.12), transparent 42%),
    linear-gradient(180deg, #F9FBF9 0%, #EFF6F1 100%);
}

.login-card {
  width: 100%;
  max-width: 680rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(168, 195, 184, 0.38);
  border-radius: 32rpx;
  padding: 54rpx 44rpx;
  box-shadow: 0 20rpx 60rpx rgba(45, 67, 57, 0.12);
  box-sizing: border-box;
}

.logo {
  text-align: center;
  margin-bottom: 46rpx;
}

.brand-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2D4339;
  letter-spacing: 6rpx;
}

.brand-subtitle {
  margin-top: 12rpx;
  color: #7FA998;
  font-size: 25rpx;
  letter-spacing: 4rpx;
}

.error-message {
  background: #fef2f2;
  color: #ef4444;
  border: 1rpx solid #fecaca;
  border-radius: 18rpx;
  padding: 20rpx;
  font-size: 26rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  color: #4A5D4E;
  font-size: 25rpx;
  font-weight: 700;
  margin: 0 0 12rpx 8rpx;
}

.input {
  width: 100%;
  height: 92rpx;
  padding: 0 28rpx;
  border: 1rpx solid #DDE9E2;
  border-radius: 22rpx;
  background: #F9FBF9;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #2D4339;
}

.login-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 92rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border-radius: 22rpx;
  background: #7FA998;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
  box-shadow: 0 10rpx 28rpx rgba(127, 169, 152, 0.25);
}

.tips {
  margin-top: 34rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #F3F8F5;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.7;
}

.tips-title {
  color: #4A5D4E;
  font-weight: 700;
}
