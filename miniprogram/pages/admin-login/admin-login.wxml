<view
  class="login-page {{keyboardHeight ? 'keyboard-open' : ''}}"
  style="{{keyboardHeight ? 'padding-bottom:' + (keyboardHeight + 48) + 'px;' : ''}}"
>
  <view class="login-card">
    <view class="logo">
      <view class="brand-title">欧诺造型</view>
      <view class="brand-subtitle">智慧管理控制台</view>
    </view>

    <view wx:if="{{error}}" class="error-message">{{error}}</view>

    <view class="form-group">
      <text class="label">用户名</text>
      <input
        class="input"
        value="{{username}}"
        adjust-position="{{true}}"
        cursor-spacing="180"
        bindinput="onUsernameInput"
        bindfocus="onFormFocus"
        placeholder="请输入用户名"
      />
    </view>

    <view class="form-group">
      <text class="label">密码</text>
      <input
        class="input"
        value="{{password}}"
        password
        adjust-position="{{true}}"
        cursor-spacing="220"
        bindinput="onPasswordInput"
        bindfocus="onFormFocus"
        placeholder="请输入密码"
        confirm-type="done"
        bindconfirm="login"
      />
    </view>

    <button class="login-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="login">{{loading ? '登录中...' : '登录'}}</button>
  </view>
</view>
