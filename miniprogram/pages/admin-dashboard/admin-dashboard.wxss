.admin-page {
  min-height: 100vh;
  background: #F7FAF8;
  padding: 28rpx;
  box-sizing: border-box;
  color: #2D4339;
}

.header-actions {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
  padding: 20rpx 12rpx;
  border-radius: 20rpx;
  background: #E8F3EE;
  color: #4F7D6B;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: center;
}

.action-btn.home {
  background: #F3EDE7;
  color: #8A6B4D;
}

.refresh-btn {
  flex-shrink: 0;
  width: auto;
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  background: #E8F3EE;
  color: #4F7D6B;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-card,
.section {
  background: #ffffff;
  border: 1rpx solid #E3EEE8;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(45, 67, 57, 0.06);
}

.stat-card {
  padding: 24rpx 18rpx;
  text-align: center;
}

.stat-label {
  color: #81948B;
  font-size: 23rpx;
}

.stat-num {
  margin-top: 8rpx;
  font-size: 44rpx;
  color: #4F7D6B;
  font-weight: 800;
}

.section {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.slot-toolbar {
  position: relative;
  z-index: 30;
  gap: 16rpx;
}

.slot-toolbar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.slot-date-dropdown {
  position: relative;
  flex-shrink: 0;
}

.slot-date-trigger {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border: 1rpx solid #DDE9E2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #4F7D6B;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(127, 169, 152, 0.1);
}

.slot-date-arrow {
  font-size: 20rpx;
  color: #8CA097;
  transition: transform 0.2s ease;
}

.slot-date-arrow.open {
  transform: rotate(180deg);
}

.slot-date-menu {
  position: absolute;
  top: calc(100% + 8rpx);
  left: 0;
  min-width: 140rpx;
  background: #ffffff;
  border: 1rpx solid #DDE9E2;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(45, 67, 57, 0.12);
  overflow: hidden;
  z-index: 40;
}

.slot-date-option {
  padding: 18rpx 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4F7D6B;
  text-align: center;
}

.slot-date-option.active {
  background: #E8F3EE;
  color: #2D6A4F;
}

.slot-date-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: transparent;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.booking-tabs {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.booking-tab {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #F3F5F4;
  color: #64748B;
}

.booking-tab.active {
  background: #E8F5EE;
  color: #2D6A4F;
}

.tab-label {
  font-size: 24rpx;
  font-weight: 700;
}

.tab-count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(100, 116, 139, 0.12);
  color: inherit;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
}

.booking-tab.active .tab-count {
  background: rgba(45, 106, 79, 0.14);
}

.tab-indicator {
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  width: 36rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #2D6A4F;
  transform: translateX(-50%);
}

.empty {
  padding: 60rpx 0;
  text-align: center;
  color: #94a3b8;
}

.timeline-container {
  position: relative;
  overflow: visible;
}

.timeline-item {
  position: relative;
  margin-bottom: 16rpx;
  padding-left: 112rpx;
  box-sizing: border-box;
  overflow: visible;
}

.timeline-item.last {
  margin-bottom: 0;
}

.timeline-time {
  position: absolute;
  left: 0;
  top: 0;
  width: 104rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: flex-end;
  box-sizing: border-box;
}

.time-hour,
.time-minute {
  flex-shrink: 0;
  width: 40rpx;
  font-size: 32rpx;
  color: #8A6B4D;
  font-weight: 600;
  line-height: 38rpx;
}

.time-hour {
  text-align: right;
}

.time-minute {
  text-align: left;
}

.time-colon {
  font-size: 32rpx;
  color: #8A6B4D;
  font-weight: 600;
  line-height: 38rpx;
}

.time-colon-col {
  flex-shrink: 0;
  width: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  margin-top: 6rpx;
  border-radius: 50%;
  background: #5F8F7A;
  box-shadow: 0 0 0 6rpx #E8F3EE;
  z-index: 2;
}

.timeline-segment {
  position: absolute;
  width: 2rpx;
  min-height: 24rpx;
  background-color: #ECEEEC;
  z-index: 1;
  pointer-events: none;
}

.timeline-card {
  width: 100%;
  min-width: 0;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  border: 1rpx solid #E3EEE8;
  box-shadow: 0 8rpx 40rpx rgba(127, 169, 152, 0.08);
  box-sizing: border-box;
}

.timeline-card.cut-service {
  background: #E8F3EE;
  border-left: 8rpx solid #7FA998;
}

.timeline-card.dye-service {
  background: rgba(232, 213, 196, 0.3);
  border-left: 8rpx solid #8A6B4D;
}

.timeline-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.appointment-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #2D4339;
  letter-spacing: 0.02em;
  line-height: 1.1;
}

.timeline-card-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.btn-cancel {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  background: #fee2e2;
  color: #ef4444;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  box-shadow: 0 4rpx 8rpx rgba(239, 68, 68, 0.1);
}

.btn-complete {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  background: #10B981;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  box-shadow: 0 4rpx 8rpx rgba(16, 185, 129, 0.2);
}

.btn-complete.disabled {
  background: #E3EEE8;
  color: #8A6B4D;
  opacity: 0.6;
  box-shadow: none;
}

.timeline-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 10rpx;
}

.footer-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  min-width: 0;
}

.service-tag {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.05em;
  line-height: 1.2;
}

.service-tag.cut,
.service-tag.dye {
  color: #7FA998;
}

.user-type-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.user-type-badge.new-user {
  background: #e8f5e9;
  color: #2e7d32;
  border: 1rpx solid #a5d6a7;
}

.user-type-badge.old-user {
  background: #fff3e0;
  color: #e65100;
  border: 1rpx solid #ffcc80;
}

.contact-btn {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid #E3EEE8;
  color: #2D4339;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.contact-btn-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.appointment-actions,
.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 22rpx;
}

.small-btn {
  min-width: 130rpx;
  padding: 16rpx 22rpx;
  border-radius: 18rpx;
  background: #7FA998;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.small-btn.muted {
  background: #EEF4F0;
  color: #4F7D6B;
}

.slots-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.slot {
  min-height: 96rpx;
  border-radius: 32rpx;
  border: 1rpx solid #E3EEE8;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  box-sizing: border-box;
}

.slot-time {
  font-size: 24rpx;
  font-weight: 700;
  color: #2D4339;
  white-space: nowrap;
}

.slot-status {
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0.05em;
}

.slot.booked {
  background: rgba(254, 243, 199, 0.6);
  border-color: rgba(251, 146, 60, 0.4);
  opacity: 0.7;
}

.slot.booked .slot-time {
  color: #2D4339;
}

.slot.booked .slot-status {
  color: rgba(234, 88, 12, 0.9);
}

.slot.completed {
  background: rgba(219, 234, 254, 0.6);
  border-color: rgba(59, 130, 246, 0.4);
  opacity: 0.7;
}

.slot.completed .slot-status {
  color: rgba(37, 99, 235, 0.9);
}

.slot.blocked {
  background: rgba(254, 226, 226, 0.6);
  border-color: rgba(239, 68, 68, 0.4);
}

.slot.blocked .slot-status {
  color: rgba(220, 38, 38, 0.9);
}

.slot.available {
  background: rgba(220, 252, 231, 0.6);
  border-color: rgba(34, 197, 94, 0.4);
  box-shadow: 0 8rpx 40rpx rgba(127, 169, 152, 0.08);
}

.slot.available .slot-status {
  color: rgba(22, 163, 74, 0.9);
}

.slot.expired {
  background: rgba(241, 245, 249, 0.8);
  border-color: rgba(148, 163, 184, 0.5);
  opacity: 0.7;
}

.slot.expired .slot-time,
.slot.expired .slot-status {
  color: rgba(100, 116, 139, 0.8);
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.28);
  z-index: 1000;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.96);
  width: 86%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 34rpx;
  box-sizing: border-box;
  z-index: 1200;
  visibility: hidden;
  opacity: 0;
}

.modal.show {
  visibility: visible;
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
  text-align: center;
}

.date-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.date-picker,
.textarea {
  border: 1rpx solid #DDE9E2;
  border-radius: 18rpx;
  background: #F9FBF9;
  padding: 22rpx;
  font-size: 26rpx;
  color: #2D4339;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
}

.saved-ranges {
  margin-bottom: 18rpx;
}

.range-row {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 64rpx;
  padding: 14rpx 88rpx 14rpx 16rpx;
  border-radius: 14rpx;
  background: #F3F8F5;
  margin-bottom: 10rpx;
  box-sizing: border-box;
}

.range-date {
  width: 100%;
  font-size: 22rpx;
  color: #2D4339;
  line-height: 1.4;
  white-space: nowrap;
}

.range-delete-btn {
  position: absolute;
  top: 50%;
  right: 16rpx;
  transform: translateY(-50%);
  padding: 8rpx 0;
  color: #ef4444;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.modal-error {
  margin-top: 16rpx;
  color: #ef4444;
  font-size: 24rpx;
  text-align: center;
}
