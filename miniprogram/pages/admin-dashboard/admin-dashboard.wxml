<view class="admin-page">
  <view class="header-actions">
    <button class="action-btn" bindtap="openVacationModal">休假设置</button>
    <button class="action-btn" bindtap="openAnnouncementModal">公告设置</button>
    <button class="action-btn home" bindtap="goHome">返回首页</button>
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-label">待履约</view>
      <view class="stat-num">{{stats.pending}}</view>
    </view>
    <view class="stat-card">
      <view class="stat-label">已完成</view>
      <view class="stat-num">{{stats.completed}}</view>
    </view>
    <view class="stat-card">
      <view class="stat-label">所有预约</view>
      <view class="stat-num">{{stats.all}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">预约列表 <text class="last-time">{{lastUpdateTime}}</text></view>
      <view class="refresh-btn" bindtap="loadAppointments">刷新</view>
    </view>
    <view class="tabs">
      <view wx:for="{{filters}}" wx:key="key" class="tab {{currentFilter === item.key ? 'active' : ''}}" bindtap="setFilter" data-key="{{item.key}}">{{item.label}}</view>
    </view>

    <view wx:if="{{filteredAppointments.length === 0}}" class="empty">暂无预约</view>
    <view wx:else class="timeline-container">
      <view
        wx:for="{{filteredAppointments}}"
        wx:key="id"
        class="timeline-item {{index === filteredAppointments.length - 1 ? 'last' : ''}}"
      >
        <view class="timeline-time">{{item.timeDisplay}}</view>
        <view class="timeline-segment"></view>
        <view class="timeline-card {{item.serviceType === 'dye' ? 'dye-service' : 'cut-service'}}">
          <view class="timeline-card-header">
            <view class="appointment-name">{{item.phoneLast4}}</view>
            <view class="timeline-card-actions" wx:if="{{item.canOperate}}">
              <view class="btn-cancel" bindtap="adminCancel" data-id="{{item.id}}">取消</view>
              <view
                class="btn-complete {{item.canComplete ? '' : 'disabled'}}"
                bindtap="completeAppointment"
                data-id="{{item.id}}"
                data-enabled="{{item.canComplete}}"
              >完成</view>
            </view>
          </view>
          <view class="timeline-card-footer">
            <view class="footer-tags">
              <text class="service-tag {{item.serviceType === 'dye' ? 'dye' : 'cut'}}">{{item.serviceTypeText}}</text>
              <text wx:if="{{item.hasNewUserTag}}" class="user-type-badge {{item.isNewUser ? 'new-user' : 'old-user'}}">{{item.isNewUser ? '新客' : '老客'}}</text>
            </view>
            <view wx:if="{{item.phone}}" class="contact-btn" bindtap="contactCustomer" data-phone="{{item.phone}}">
              <image class="contact-btn-icon" src="/images/action-phone.svg" mode="aspectFit"></image>
              <text>联系客户</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header slot-toolbar">
      <view class="slot-toolbar-left">
        <view class="section-title">时间段管理</view>
        <view class="slot-date-dropdown">
          <view class="slot-date-trigger" bindtap="toggleSlotDateMenu">
            <text>{{selectedSlotDateLabel}}</text>
            <text class="slot-date-arrow {{slotDateMenuVisible ? 'open' : ''}}">▾</text>
          </view>
          <view wx:if="{{slotDateMenuVisible}}" class="slot-date-menu">
            <view
              wx:for="{{slotDateOptions}}"
              wx:key="key"
              class="slot-date-option {{slotDateIndex === index ? 'active' : ''}}"
              bindtap="selectSlotDate"
              data-index="{{index}}"
            >{{item.label}}</view>
          </view>
        </view>
      </view>
      <view class="refresh-btn" bindtap="loadTimeSlots">刷新</view>
    </view>
    <view wx:if="{{slotDateMenuVisible}}" class="slot-date-mask" bindtap="closeSlotDateMenu"></view>
    <view class="slots-grid">
      <view wx:for="{{slotItems}}" wx:key="time" class="slot {{item.adminClass}}" bindtap="toggleSlot" data-time="{{item.time}}" data-can-toggle="{{item.canToggle}}">
        <view class="slot-time">{{item.displayTime}}</view>
        <text class="slot-status {{item.adminClass}}">{{item.adminText}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{modalMask}}" class="modal-mask" bindtap="closeModals"></view>

  <view wx:if="{{vacationVisible}}" class="modal show">
    <view class="modal-title">休假设置</view>
    <view class="saved-ranges" wx:if="{{vacationRanges.length > 0}}">
      <view wx:for="{{vacationRanges}}" wx:key="index" class="range-row">
        <view class="range-date">{{item.vacationStartDate}} - {{item.vacationEndDate}}</view>
        <view class="range-delete-btn" bindtap="removeVacationRange" data-index="{{index}}">删除</view>
      </view>
    </view>
    <view class="date-row">
      <picker mode="date" value="{{vacationStartDate}}" start="{{today}}" bindchange="onVacationStartChange">
        <view class="date-picker">开始：{{vacationStartDate}}</view>
      </picker>
      <picker mode="date" value="{{vacationEndDate}}" start="{{today}}" bindchange="onVacationEndChange">
        <view class="date-picker">结束：{{vacationEndDate}}</view>
      </picker>
    </view>
    <view wx:if="{{vacationError}}" class="modal-error">{{vacationError}}</view>
    <view class="modal-actions">
      <button class="small-btn muted" bindtap="clearVacation">清空休假</button>
      <button class="small-btn" bindtap="saveVacation">保存</button>
    </view>
  </view>

  <view wx:if="{{announcementVisible}}" class="modal show">
    <view class="modal-title">公告设置</view>
    <textarea class="textarea" value="{{announcementText}}" bindinput="onAnnouncementInput" placeholder="例如：欢迎光临欧诺造型 · 营业时间 11:00-22:00"></textarea>
    <view wx:if="{{announcementError}}" class="modal-error">{{announcementError}}</view>
    <view class="modal-actions">
      <button class="small-btn muted" bindtap="closeModals">取消</button>
      <button class="small-btn" bindtap="saveAnnouncement">保存</button>
    </view>
  </view>
</view>
