<view class="page-shell">
  <view class="page-bg"></view>
  <view class="admin-hotspot" bindtap="openAdminLogin"></view>

  <view class="container">
    <view class="header">
      <view class="title">欧诺造型 <text class="title-dot">·</text> 预约服务</view>
      <view class="subtitle">Premium Salon Selection</view>
    </view>

    <view class="announcement-bar">
      <view class="announcement-inner">
        <text class="announcement-icon">⌾</text>
        <view class="announcement-wrap {{announcementScrollable ? 'scrollable' : ''}}">
          <view class="announcement-track">
            <text class="announcement-text">{{announcementText}}</text>
            <text class="announcement-text duplicate">{{announcementText}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="booking-buttons">
      <view class="booking-btn btn-cut {{bookingDisabled ? 'disabled' : ''}}" bindtap="openBook" data-type="cut">
        <view class="btn-icon-wrapper">
          <image src="/images/11.png" mode="aspectFit" class="btn-icon"></image>
        </view>
        <view class="btn-content">
          <view class="btn-title">{{bookingDisabled ? '不可预约' : '预约剪发'}}</view>
          <view class="btn-desc">{{bookingDisabled ? '发型师休假中' : 'Professional Haircut Service'}}</view>
        </view>
        <text class="btn-arrow">›</text>
      </view>

      <view class="booking-btn btn-dye {{bookingDisabled ? 'disabled' : ''}}" bindtap="openBook" data-type="dye">
        <view class="btn-icon-wrapper dye-icon">
          <image src="/images/22.png" mode="aspectFit" class="btn-icon"></image>
        </view>
        <view class="btn-content">
          <view class="btn-title">{{bookingDisabled ? '不可预约' : '预约烫染'}}</view>
          <view class="btn-desc">{{bookingDisabled ? '发型师休假中' : 'Perm & Color Artistry'}}</view>
        </view>
        <text class="btn-arrow dye-arrow">›</text>
      </view>
    </view>

    <view class="link-row">
      <button class="progress-link" bindtap="openProgressModal">排队查询 Progress</button>
      <button class="cancel-link" bindtap="openCancelModal">取消预约 Cancel</button>
    </view>
  </view>

  <view wx:if="{{maskVisible}}" class="overlay" bindtap="closeAll"></view>

  <view class="drawer {{drawerVisible ? 'show' : ''}}">
    <button class="close-btn" bindtap="closeDrawer">×</button>
    <view class="drawer-title">预约{{selectedServiceType === 'dye' ? '烫染' : '剪发'}} - 选择时间</view>
    <view class="date-tabs">
      <view wx:for="{{dateTabs}}" wx:key="date" class="date-tab {{selectedDate === item.date ? 'active' : ''}}" bindtap="switchDate" data-date="{{item.date}}">
        <view>{{item.day}}</view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <scroll-view class="slot-scroll-area" scroll-y>
      <view class="slot-grid {{slotsUpdating ? 'updating' : ''}}">
        <view wx:if="{{slotsLoading}}" class="grid-message">加载中...</view>
        <view wx:elif="{{slotItems.length === 0}}" class="grid-message">该日期暂不可预约</view>
        <view wx:for="{{slotItems}}" wx:key="time" class="slot {{item.statusClass}}" bindtap="selectTimeSlot" data-time="{{item.time}}" data-clickable="{{item.clickable}}">
          <view class="slot-time">{{item.displayTime}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="phone-modal {{phoneModalVisible ? 'show' : ''}}">
    <view class="modal-title">请输入手机号</view>
    <input class="modal-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phoneInput}}" bindinput="onPhoneInput" confirm-type="done" bindconfirm="confirmBooking" />
    <view class="error-msg {{phoneError ? 'show' : ''}}">{{phoneError}}</view>
    <view class="btn-group">
      <button class="confirm-btn" bindtap="confirmBooking">确认预约</button>
      <button class="confirm-btn secondary" bindtap="closePhoneModal">取 消</button>
    </view>
  </view>

  <view class="success-modal {{successVisible ? 'show' : ''}}">
    <view class="success-icon">✓</view>
    <view class="success-title">预约成功</view>
    <view class="success-block">
      <view class="success-label">您的预约号</view>
      <view class="success-no">{{displayId || '---'}}</view>
    </view>
    <view class="success-note">到店请出示您的预约号</view>
    <view class="success-note">取消预约请使用手机号</view>
    <button class="confirm-btn single" bindtap="closeAll">确 认</button>
  </view>

  <view class="cancel-modal {{cancelModalVisible ? 'show' : ''}}">
    <button class="modal-close" bindtap="closeCancelModal">×</button>
    <view class="modal-title">取消预约</view>
    <view wx:if="{{cancelStep === 1}}">
      <input class="modal-input" type="number" maxlength="11" placeholder="请输入预约时的手机号" value="{{cancelPhone}}" bindinput="onCancelPhoneInput" confirm-type="search" bindconfirm="queryAppointments" />
      <view class="inline-error" wx:if="{{cancelError}}">{{cancelError}}</view>
      <button class="cancel-btn" bindtap="queryAppointments">查询预约</button>
    </view>
    <view wx:else>
      <view class="modal-hint">请选择要取消的预约：</view>
      <scroll-view class="appointments-list" scroll-y>
        <label wx:for="{{cancellableAppointments}}" wx:key="id" class="appointment-row active-row">
          <checkbox value="{{item.id}}" checked="{{item.checked}}" bindtap="toggleAppointment" data-id="{{item.id}}" />
          <view class="appointment-main">
            <view class="appointment-title">{{item.dateText}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
            <view class="appointment-sub">预约号: {{item.appId}}</view>
          </view>
        </label>
        <view wx:if="{{nonCancellableAppointments.length > 0}}" class="not-cancellable-title">以下预约无法取消：</view>
        <view wx:for="{{nonCancellableAppointments}}" wx:key="id" class="appointment-row disabled-row">
          <view class="appointment-main">
            <view class="appointment-title">{{item.dateText}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
            <view class="appointment-reason">{{item.reason || '无法取消'}}</view>
          </view>
        </view>
      </scroll-view>
      <view class="inline-error" wx:if="{{cancelError2}}">{{cancelError2}}</view>
      <view class="two-actions">
        <button class="cancel-btn" bindtap="confirmCancel">确认取消</button>
        <button class="cancel-btn muted" bindtap="backToCancelStep1">返回</button>
      </view>
    </view>
  </view>

  <view class="progress-modal {{progressModalVisible ? 'show' : ''}}">
    <button class="modal-close" bindtap="closeProgressModal">×</button>
    <view class="modal-title">排队查询</view>
    <view wx:if="{{progressStep === 1}}">
      <input class="modal-input" type="number" maxlength="11" placeholder="请输入预约时的手机号" value="{{progressPhone}}" bindinput="onProgressPhoneInput" confirm-type="search" bindconfirm="queryProgress" />
      <view class="inline-error" wx:if="{{progressError}}">{{progressError}}</view>
      <button class="progress-query-btn" bindtap="queryProgress">查询排队</button>
    </view>
    <view wx:else>
      <view class="modal-hint">根据当前排队情况预估您的预约推迟时间</view>
      <scroll-view class="progress-list" scroll-y>
        <view wx:for="{{progressRows}}" wx:key="key" class="progress-card">
          <view class="progress-title">{{item.dateStr}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
          <view class="appointment-sub">预约号: {{item.appId}}</view>
          <view class="progress-line">
            <block wx:if="{{item.hasAheadCount}}">您前面还有<text class="red-num"> {{item.aheadCount}} </text>位已预约未完成的客户</block>
            <block wx:else>{{item.delayLine1}}</block>
          </view>
          <view wx:if="{{item.delayLine2}}" class="progress-line second">
            <text>{{item.delayLine2}}</text><text wx:if="{{item.numberPart}}" class="red-num small"> {{item.numberPart}}</text>
          </view>
        </view>
      </scroll-view>
      <button class="progress-query-btn close-progress" bindtap="closeProgressModal">关 闭</button>
    </view>
  </view>
</view>
