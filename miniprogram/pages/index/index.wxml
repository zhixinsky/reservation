<view class="page-shell">
  <image class="page-bg" src="{{pageBgUrl}}" mode="aspectFill" lazy-load="{{false}}"></image>

  <view
    wx:if="{{storePickerVisible}}"
    class="store-capsule-wrap"
    style="width: {{storeCapsuleWidth}}rpx;"
    catchtap="toggleStoreMenu"
  >
    <view class="store-capsule">
      <text class="store-capsule-name">{{selectedStoreName}}</text>
      <text class="store-capsule-arrow">▾</text>
    </view>
    <view wx:if="{{storeMenuVisible}}" class="store-menu" catchtap="">
      <view
        wx:for="{{storeList}}"
        wx:key="id"
        class="store-menu-item {{selectedStoreId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        catchtap="onSelectStore"
      >{{item.name}}</view>
    </view>
  </view>

  <view class="page-foreground">
  <view class="container">
    <view class="header">
      <view class="title">
        <text class="title-text">{{selectedStoreName}}</text>
        <text class="title-dot">·</text>
        <text class="title-text">预约服务</text>
      </view>
      <view class="subtitle">Premium Salon Selection</view>
    </view>

    <view class="announcement-bar">
      <view class="announcement-inner">
        <image class="announcement-icon" src="/images/bell.svg" mode="aspectFit"></image>
        <view class="announcement-wrap {{announcementScrollable ? 'scrollable' : ''}}" id="announcementWrap">
          <view class="announcement-track" id="announcementTrack" style="{{announcementTrackStyle}}">
            <view class="announcement-segment">
              <text class="announcement-text" id="announcementText">{{announcementText}}</text>
            </view>
            <view class="announcement-segment">
              <text class="announcement-text">{{announcementText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="booking-buttons">
      <view class="booking-btn btn-cut {{bookingDisabled ? 'disabled' : ''}}" bindtap="openBook" data-type="cut">
        <view class="btn-icon-wrapper">
          <image src="/images/11.png" mode="aspectFit" class="btn-icon"></image>
        </view>
        <view class="btn-content">
          <view class="btn-title">{{bookingDisabled ? '不可预约' : '预约剪发'}}</view>
          <view class="btn-desc">{{bookingDisabled ? '发型师休假中' : 'Professional Haircut Service'}}</view>
        </view>
        <text class="btn-arrow">›</text>
      </view>

      <view class="booking-btn btn-dye {{bookingDisabled ? 'disabled' : ''}}" bindtap="openBook" data-type="dye">
        <view class="btn-icon-wrapper dye-icon">
          <image src="/images/22.png" mode="aspectFit" class="btn-icon"></image>
        </view>
        <view class="btn-content">
          <view class="btn-title">{{bookingDisabled ? '不可预约' : '预约烫染'}}</view>
          <view class="btn-desc">{{bookingDisabled ? '发型师休假中' : 'Perm & Color Artistry'}}</view>
        </view>
        <text class="btn-arrow dye-arrow">›</text>
      </view>
    </view>

  </view>

  <view
    class="overlay booking-overlay {{!useWorkletDrawer && maskVisible ? 'show' : ''}}"
    bindtap="closeAll"
  ></view>
  <view
    wx:if="{{storeMenuVisible}}"
    class="store-menu-mask"
    bindtap="closeStoreMenu"
  ></view>

  <view class="drawer booking-drawer {{drawerVisible ? 'active' : ''}} {{drawerVisible && !useWorkletDrawer ? 'show' : ''}}">
    <view class="close-btn" bindtap="closeDrawer">×</view>
    <view class="drawer-title">预约{{selectedServiceType === 'dye' ? '烫染' : '剪发'}} - 选择时间</view>
    <view class="date-tabs">
      <view wx:for="{{dateTabs}}" wx:key="date" class="date-tab {{selectedDate === item.date ? 'active' : ''}}" bindtap="switchDate" data-date="{{item.date}}">
        <view>{{item.day}}</view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <scroll-view class="slot-scroll-area" scroll-y enhanced type="list" show-scrollbar="{{false}}">
      <view class="slot-grid {{slotsUpdating ? 'updating' : ''}}">
        <view wx:if="{{slotsLoading}}" class="grid-message">加载中...</view>
        <view wx:elif="{{slotItems.length === 0}}" class="grid-message">该日期暂不可预约</view>
        <view wx:for="{{slotItems}}" wx:key="time" class="slot {{item.statusClass}}" bindtap="selectTimeSlot" data-time="{{item.time}}" data-clickable="{{item.clickable}}">
          <view class="slot-time">{{item.displayTime}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="phone-modal confirm-modal {{confirmModalVisible ? 'show' : ''}}">
    <view class="modal-title">确认预约信息</view>
    <view class="confirm-info">
      <view class="confirm-row">
        <text class="confirm-label">服务项目</text>
        <text class="confirm-value">{{confirmServiceLabel}}</text>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">预约日期</text>
        <text class="confirm-value">{{confirmDateLabel}}</text>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">预约时间</text>
        <text class="confirm-value">{{confirmTimeLabel}}</text>
      </view>
    </view>
    <view class="btn-group">
      <button class="confirm-btn" bindtap="onConfirmBooking">确认预约</button>
      <button class="confirm-btn secondary" bindtap="closeConfirmModal">取 消</button>
    </view>
  </view>

  <view class="phone-modal {{phoneModalVisible ? 'show' : ''}}">
    <view class="modal-title">手机号快速登录</view>
    <view class="modal-hint">用于生成预约号并接收预约提醒</view>
    <view class="error-msg {{phoneError ? 'show' : ''}}">{{phoneError}}</view>
    <view class="btn-group">
      <button class="confirm-btn" open-type="getPhoneNumber" bindgetphonenumber="onBookingPhoneNumber">手机号快速登录</button>
      <button class="confirm-btn secondary" bindtap="closePhoneModal">取 消</button>
    </view>
  </view>

  <view class="alert-modal {{alertModalVisible ? 'show' : ''}}">
    <view class="alert-icon">!</view>
    <view class="alert-title">{{alertModalTitle}}</view>
    <view class="alert-block" wx:if="{{alertModalAppId}}">
      <view class="alert-label">已有预约号</view>
      <view class="alert-no">{{alertModalAppId}}</view>
      <view class="alert-date" wx:if="{{alertModalDateLabel}}">{{alertModalDateLabel}}</view>
    </view>
    <view class="alert-message">{{alertModalMessage}}</view>
    <button class="confirm-btn single" bindtap="closeAlertModal">我知道了</button>
  </view>

  <view class="success-modal {{successVisible ? 'show' : ''}}">
    <view class="success-icon">
      <image class="success-icon-img" src="/images/success-check.svg" mode="aspectFit"></image>
    </view>
    <view class="success-title">预约成功</view>
    <view class="success-block">
      <view class="success-label">您的预约号</view>
      <view class="success-no">{{displayId || '---'}}</view>
    </view>
    <view class="success-info">
      <view class="success-row">
        <text class="success-row-label">服务项目</text>
        <text class="success-row-value">{{successServiceLabel}}</text>
      </view>
      <view class="success-row">
        <text class="success-row-label">预约日期</text>
        <text class="success-row-value">{{successDateLabel}}</text>
      </view>
      <view class="success-row">
        <text class="success-row-label">预约时间</text>
        <text class="success-row-value">{{successTimeLabel}}</text>
      </view>
      <view class="success-row success-row-stylist">
        <text class="success-row-label">发型师</text>
        <view class="success-stylist">
          <image class="success-stylist-avatar" src="{{successStylistAvatar}}" mode="aspectFill"></image>
          <view class="success-stylist-text">
            <text class="success-stylist-name">{{successStylistName}}</text>
            <text wx:if="{{successStylistRank}}" class="success-stylist-rank">{{successStylistRank}}</text>
          </view>
        </view>
      </view>
    </view>
    <button class="confirm-btn single" bindtap="closeAll">确 认</button>
  </view>

  </view>
</view>
