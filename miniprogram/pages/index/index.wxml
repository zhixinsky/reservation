<view class="page-shell">
  <view class="page-bg"></view>
  <view class="admin-hotspot" bindtap="openAdminLogin"></view>

  <view class="container">
    <view class="header">
      <view class="title">欧诺造型 <text class="title-dot">·</text> 预约服务</view>
      <view class="subtitle">Premium Salon Selection</view>
    </view>

    <view class="announcement-bar">
      <view class="announcement-inner">
        <text class="announcement-icon">⌾</text>
        <view class="announcement-wrap {{announcementScrollable ? 'scrollable' : ''}}">
          <view class="announcement-track">
            <text class="announcement-text">{{announcementText}}</text>
            <text class="announcement-text duplicate">{{announcementText}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="booking-buttons">
      <view class="booking-btn btn-cut {{bookingDisabled ? 'disabled' : ''}}" bindtap="openBook" data-type="cut">
        <view class="btn-icon-wrapper">
          <image src="/images/11.png" mode="aspectFit" class="btn-icon"></image>
        </view>
        <view class="btn-content">
          <view class="btn-title">{{bookingDisabled ? '不可预约' : '预约剪发'}}</view>
          <view class="btn-desc">{{bookingDisabled ? '发型师休假中' : 'Professional Haircut Service'}}</view>
        </view>
        <text class="btn-arrow">›</text>
      </view>

      <view class="booking-btn btn-dye {{bookingDisabled ? 'disabled' : ''}}" bindtap="openBook" data-type="dye">
        <view class="btn-icon-wrapper dye-icon">
          <image src="/images/22.png" mode="aspectFit" class="btn-icon"></image>
        </view>
        <view class="btn-content">
          <view class="btn-title">{{bookingDisabled ? '不可预约' : '预约烫染'}}</view>
          <view class="btn-desc">{{bookingDisabled ? '发型师休假中' : 'Perm & Color Artistry'}}</view>
        </view>
        <text class="btn-arrow dye-arrow">›</text>
      </view>
    </view>

  </view>

  <view wx:if="{{maskVisible}}" class="overlay" bindtap="closeAll"></view>

  <view class="drawer {{drawerVisible ? 'show' : ''}}">
    <view class="close-btn" bindtap="closeDrawer">×</view>
    <view class="drawer-title">预约{{selectedServiceType === 'dye' ? '烫染' : '剪发'}} - 选择时间</view>
    <view class="date-tabs">
      <view wx:for="{{dateTabs}}" wx:key="date" class="date-tab {{selectedDate === item.date ? 'active' : ''}}" bindtap="switchDate" data-date="{{item.date}}">
        <view>{{item.day}}</view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <scroll-view class="slot-scroll-area" scroll-y>
      <view class="slot-grid {{slotsUpdating ? 'updating' : ''}}">
        <view wx:if="{{slotsLoading}}" class="grid-message">加载中...</view>
        <view wx:elif="{{slotItems.length === 0}}" class="grid-message">该日期暂不可预约</view>
        <view wx:for="{{slotItems}}" wx:key="time" class="slot {{item.statusClass}}" bindtap="selectTimeSlot" data-time="{{item.time}}" data-clickable="{{item.clickable}}">
          <view class="slot-time">{{item.displayTime}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="phone-modal {{phoneModalVisible ? 'show' : ''}}">
    <view class="modal-title">授权手机号</view>
    <view class="modal-hint">用于生成预约号并接收预约提醒</view>
    <view class="error-msg {{phoneError ? 'show' : ''}}">{{phoneError}}</view>
    <view class="btn-group">
      <button class="confirm-btn" open-type="getPhoneNumber" bindgetphonenumber="onBookingPhoneNumber">手机号快速验证</button>
      <button class="confirm-btn secondary" bindtap="closePhoneModal">取 消</button>
    </view>
  </view>

  <view class="success-modal {{successVisible ? 'show' : ''}}">
    <view class="success-icon">✓</view>
    <view class="success-title">预约成功</view>
    <view class="success-block">
      <view class="success-label">您的预约号</view>
      <view class="success-no">{{displayId || '---'}}</view>
    </view>
    <view class="success-note">到店请出示您的预约号</view>
    <view class="success-note">取消预约请使用手机号</view>
    <button class="confirm-btn single" bindtap="closeAll">确 认</button>
  </view>

</view>
