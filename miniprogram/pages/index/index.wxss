.page-shell {
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  box-sizing: border-box;
  overflow: hidden;
}

.page-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 20% 50%, rgba(167, 196, 160, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(232, 213, 196, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 40% 20%, rgba(167, 196, 160, 0.05) 0%, transparent 50%);
  z-index: 0;
}

.admin-hotspot {
  position: fixed;
  top: 0;
  left: 0;
  width: 160rpx;
  height: 160rpx;
  z-index: 100;
  background: transparent;
}

.container {
  width: 670rpx;
  max-width: 670rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 80rpx;
  position: relative;
  z-index: 1;
}

.header {
  text-align: center;
  margin-bottom: 20rpx;
}

.title {
  font-family: "Songti SC", "STSong", serif;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #111827;
  margin-bottom: 16rpx;
}

.title-dot {
  color: #4A5D4E;
  font-weight: 300;
}

.subtitle {
  font-size: 26rpx;
  color: #9ca3af;
  font-weight: 300;
  text-transform: uppercase;
  letter-spacing: 6rpx;
}

.announcement-bar {
  width: 100%;
  margin-top: -40rpx;
}

.announcement-inner {
  height: 72rpx;
  border: 1rpx solid rgba(167, 196, 160, 0.35);
  border-radius: 9999rpx;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(45, 67, 57, 0.06);
  overflow: hidden;
}

.announcement-icon {
  width: 42rpx;
  color: #2D6A4F;
  font-size: 32rpx;
  flex-shrink: 0;
}

.announcement-wrap {
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
}

.announcement-track {
  display: inline-flex;
  min-width: 100%;
}

.announcement-wrap.scrollable .announcement-track {
  animation: announcement-scroll 10s linear infinite;
}

.announcement-text {
  flex-shrink: 0;
  padding-right: 80rpx;
  color: #4b5563;
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.announcement-wrap:not(.scrollable) .duplicate {
  display: none;
}

@keyframes announcement-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.booking-buttons {
  width: 670rpx;
  align-self: stretch;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.booking-btn {
  width: 670rpx;
  min-height: 204rpx;
  padding: 46rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 48rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 400;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 20rpx 30rpx -6rpx rgba(0, 0, 0, 0.1), 0 8rpx 12rpx -4rpx rgba(0, 0, 0, 0.05);
  text-align: left;
  box-sizing: border-box;
  overflow: visible;
}

.booking-btn.disabled {
  opacity: 0.5;
}

.btn-cut {
  background: rgba(233, 240, 232, 0.8);
}

.btn-dye {
  background: rgba(245, 239, 230, 0.8);
}

.btn-icon-wrapper {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(74, 93, 78, 0.1);
}

.dye-icon {
  background: rgba(212, 195, 163, 0.2);
}

.btn-icon {
  width: 96rpx;
  height: 96rpx;
}

.btn-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.btn-title {
  font-family: "Songti SC", "STSong", serif;
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.btn-desc {
  font-size: 23rpx;
  color: #6b7280;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.btn-arrow {
  color: #d1d5db;
  font-size: 50rpx;
  flex-shrink: 0;
}

.dye-arrow {
  color: #E8D5C4;
}

.link-row {
  margin-top: 56rpx;
  display: flex;
  align-items: stretch;
  justify-content: center;
  gap: 24rpx;
  width: 100%;
  max-width: 600rpx;
}

.progress-link,
.cancel-link {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  padding: 24rpx 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 9999rpx;
  font-weight: 300;
  white-space: nowrap;
  box-sizing: border-box;
}

.progress-link {
  color: #2D6A4F;
  border-color: rgba(45, 106, 79, 0.35);
}

.cancel-link {
  color: #9ca3af;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.28);
  z-index: 900;
}

.drawer {
  position: fixed;
  bottom: -100%;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #E9F0E8;
  border-radius: 64rpx 64rpx 0 0;
  padding: 50rpx 34rpx 0;
  transition: bottom 0.35s ease;
  z-index: 1000;
  height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 48rpx rgba(45, 67, 57, 0.08);
  box-sizing: border-box;
}

.drawer.show {
  bottom: 0;
}

.close-btn,
.modal-close {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: #E9F0E8;
  color: #2D4339;
  font-size: 52rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  z-index: 10;
}

.drawer-title,
.modal-title {
  font-family: "Songti SC", "STSong", serif;
  text-align: center;
  color: #2D4339;
  font-weight: 700;
  letter-spacing: 1rpx;
  font-size: 34rpx;
  margin-bottom: 30rpx;
}

.date-tabs {
  display: flex;
  justify-content: space-around;
  margin: 30rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
  padding-bottom: 30rpx;
  flex-shrink: 0;
}

.date-tab {
  text-align: center;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  color: rgba(45, 67, 57, 0.5);
  font-size: 24rpx;
  border: 1rpx solid transparent;
}

.date-tab view {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.date-tab.active {
  color: #2D6A4F;
  background: #E8F5E9;
  border-color: #81C784;
  font-weight: 600;
}

.slot-scroll-area {
  flex: 1;
  padding: 0 16rpx 80rpx;
  box-sizing: border-box;
}

.slot-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 0 8rpx;
}

.slot-grid.updating {
  opacity: 0.5;
}

.grid-message {
  grid-column: span 3;
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.slot {
  border: 1rpx solid #E9F0E8;
  padding: 24rpx 0;
  border-radius: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: rgba(45, 67, 57, 0.6);
  background: #F9FBF9;
}

.slot.available {
  border-color: #A7C4A0;
  color: #2D4339;
  background: #ffffff;
}

.slot.unavailable {
  opacity: 0.3;
  background: #E9F0E8;
  border-color: #E9F0E8;
}

.slot-time {
  font-weight: 600;
  line-height: 1.2;
}

.phone-modal,
.success-modal,
.cancel-modal,
.progress-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 85%;
  max-width: 700rpx;
  background: #ffffff;
  border: 1rpx solid #E9F0E8;
  border-radius: 64rpx;
  padding: 60rpx 40rpx;
  z-index: 2000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.28s ease;
  box-sizing: border-box;
  box-shadow: 0 20rpx 80rpx -20rpx rgba(45, 67, 57, 0.15);
}

.phone-modal.show,
.success-modal.show,
.cancel-modal.show,
.progress-modal.show {
  visibility: visible;
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.modal-input {
  width: 100%;
  padding: 28rpx;
  background: #F9FBF9;
  border: 1rpx solid #E9F0E8;
  border-radius: 32rpx;
  color: #2D4339;
  font-size: 28rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-sizing: border-box;
}

.error-msg {
  color: #ef4444;
  font-size: 26rpx;
  text-align: center;
  display: none;
  margin-bottom: 20rpx;
}

.error-msg.show,
.inline-error {
  display: block;
  color: #ef4444;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.btn-group,
.two-actions {
  display: flex;
  gap: 20rpx;
}

.confirm-btn,
.cancel-btn,
.progress-query-btn {
  flex: 1;
  background: #2D6A4F;
  color: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(45, 106, 79, 0.18);
}

.confirm-btn.secondary,
.cancel-btn.muted {
  background: #E9F0E8;
  color: #2D4339;
  box-shadow: none;
}

.confirm-btn.single,
.close-progress {
  margin-top: 30rpx;
}

.success-modal {
  text-align: center;
  padding: 80rpx 50rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #E8F5E9;
  color: #2D6A4F;
  font-size: 62rpx;
  line-height: 120rpx;
  margin: 0 auto 24rpx;
}

.success-title {
  font-size: 30rpx;
  color: #2D4339;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.success-block {
  margin: 40rpx 0;
}

.success-label,
.success-note {
  font-size: 24rpx;
  color: rgba(45, 67, 57, 0.55);
  margin-top: 10rpx;
}

.success-no {
  font-size: 76rpx;
  color: #2D6A4F;
  font-weight: 800;
  letter-spacing: 8rpx;
}

.modal-close {
  background: transparent;
  color: #666;
  font-size: 44rpx;
  top: 24rpx;
  right: 24rpx;
}

.modal-hint {
  font-size: 26rpx;
  color: #2D4339;
  margin-bottom: 24rpx;
  text-align: center;
}

.appointments-list,
.progress-list {
  max-height: 600rpx;
  margin-bottom: 30rpx;
}

.appointment-row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.active-row {
  border: 2rpx solid #A7C4A0;
  background: #ffffff;
}

.disabled-row {
  border: 1rpx solid #e5e7eb;
  background: #f8f9fa;
  opacity: 0.75;
}

.appointment-main {
  flex: 1;
  min-width: 0;
}

.appointment-title {
  font-size: 28rpx;
  color: #2D4339;
  font-weight: 600;
}

.appointment-sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.appointment-reason {
  font-size: 22rpx;
  color: #ef4444;
  margin-top: 8rpx;
}

.not-cancellable-title {
  margin: 30rpx 0 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e5e7eb;
  color: #94a3b8;
  font-size: 24rpx;
}

.progress-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #E9F0E8;
  border-radius: 32rpx;
  background: #F9FBF9;
}

.progress-title {
  font-weight: 600;
  color: #2D4339;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.progress-line {
  font-size: 26rpx;
  color: #2D6A4F;
  font-weight: 600;
  margin-top: 10rpx;
}

.progress-line.second {
  font-size: 25rpx;
}

.red-num {
  font-weight: 800;
  color: #c62828;
  font-size: 34rpx;
}

.red-num.small {
  font-size: 30rpx;
}
