.page-shell {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.page-foreground {
  position: relative;
  z-index: 1;
  isolation: isolate;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
  padding-right: 40rpx;
  padding-bottom: calc(150rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  padding-left: 40rpx;
  box-sizing: border-box;
}

.container {
  width: 670rpx;
  max-width: 670rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 80rpx;
  position: relative;
  z-index: 1;
}

.header {
  text-align: center;
  margin-bottom: 20rpx;
}

.title {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #111827;
  margin-bottom: 16rpx;
}

.title-text,
.title-dot {
  flex-shrink: 0;
  line-height: 1.2;
}

.title-dot {
  color: #4A5D4E;
  font-weight: 300;
}

.subtitle {
  font-size: 26rpx;
  color: #9ca3af;
  font-weight: 300;
  text-transform: uppercase;
  letter-spacing: 6rpx;
}

.announcement-bar {
  width: 100%;
  overflow: hidden;
}

.announcement-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 80rpx;
  padding: 16rpx 20rpx;
  overflow: hidden;
}

.announcement-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.announcement-wrap {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.announcement-track {
  display: inline-flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  white-space: nowrap;
}

.announcement-segment {
  display: inline-flex;
  flex-shrink: 0;
  align-items: center;
  padding-right: 48rpx;
  box-sizing: border-box;
}

.announcement-wrap.scrollable .announcement-track {
  animation-name: announcement-scroll;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  will-change: transform;
}

.announcement-text {
  flex-shrink: 0;
  white-space: nowrap;
  color: rgba(45, 67, 57, 0.58);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  line-height: 1.4;
}

.announcement-wrap:not(.scrollable) .announcement-segment + .announcement-segment {
  display: none;
}

@keyframes announcement-scroll {
  0% {
    transform: translate3d(0, 0, 0);
  }
  100% {
    transform: translate3d(-50%, 0, 0);
  }
}

.booking-buttons {
  width: 670rpx;
  align-self: stretch;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  margin-top: -20px;
}

.booking-btn {
  width: 670rpx;
  min-height: 204rpx;
  padding: 46rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 48rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 400;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 16rpx 28rpx -8rpx rgba(45, 67, 57, 0.08);
  text-align: left;
  box-sizing: border-box;
  overflow: visible;
}

.booking-btn.disabled {
  opacity: 0.5;
}

.btn-cut {
  background: rgba(233, 240, 232, 0.48);
}

.btn-dye {
  background: rgba(245, 239, 230, 0.48);
}

.btn-icon-wrapper {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(74, 93, 78, 0.08);
}

.dye-icon {
  background: rgba(212, 195, 163, 0.14);
}

.btn-icon {
  width: 96rpx;
  height: 96rpx;
}

.btn-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.btn-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.btn-desc {
  font-size: 23rpx;
  color: #6b7280;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.btn-arrow {
  color: #d1d5db;
  font-size: 50rpx;
  flex-shrink: 0;
}

.dye-arrow {
  color: #E8D5C4;
}

.link-row {
  margin-top: 56rpx;
  display: flex;
  align-items: stretch;
  justify-content: center;
  gap: 24rpx;
  width: 100%;
  max-width: 600rpx;
}

.progress-link,
.cancel-link {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  padding: 24rpx 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 9999rpx;
  font-weight: 300;
  white-space: nowrap;
  box-sizing: border-box;
}

.progress-link {
  color: #2D6A4F;
  border-color: rgba(45, 106, 79, 0.35);
}

.cancel-link {
  color: #9ca3af;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.28);
  z-index: 11000;
  opacity: 0;
  pointer-events: none;
}

.booking-overlay.show {
  opacity: 1;
  pointer-events: auto;
  transition: opacity 0.28s ease;
}

.drawer,
.booking-drawer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #E9F0E8;
  border-radius: 64rpx 64rpx 0 0;
  padding: 50rpx 34rpx 0;
  z-index: 12000;
  height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 48rpx rgba(45, 67, 57, 0.08);
  box-sizing: border-box;
  transform: translateY(100%);
  will-change: transform;
}

.booking-drawer {
  pointer-events: none;
}

.booking-drawer.active {
  pointer-events: auto;
}

.booking-drawer.show {
  transform: translateY(0);
  transition: transform 0.32s cubic-bezier(0.32, 0.72, 0, 1);
}

.close-btn,
.modal-close {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: #E9F0E8;
  color: #2D4339;
  font-size: 52rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  z-index: 10;
}

.drawer .close-btn {
  min-width: 72rpx;
  max-width: 72rpx;
  min-height: 72rpx;
  max-height: 72rpx;
  padding: 0;
  margin: 0;
  line-height: 72rpx;
  box-sizing: border-box;
  overflow: hidden;
  text-align: center;
  border-radius: 999rpx;
}

.drawer-title,
.modal-title {
  text-align: center;
  color: #2D4339;
  font-weight: 700;
  letter-spacing: 1rpx;
  font-size: 34rpx;
  margin-bottom: 30rpx;
}

.date-tabs {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  margin: 30rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
  padding-bottom: 30rpx;
  flex-shrink: 0;
}

.date-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  color: rgba(45, 67, 57, 0.5);
  font-size: 24rpx;
  border: 1rpx solid transparent;
}

.date-tab view {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.date-tab.active {
  color: #2D6A4F;
  background: #E8F5E9;
  border-color: #81C784;
  font-weight: 600;
}

.slot-scroll-area {
  flex: 1;
  min-height: 0;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.slot-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-content: flex-start;
  gap: 24rpx;
  padding: 0 8rpx calc(128rpx + constant(safe-area-inset-bottom));
  padding: 0 8rpx calc(128rpx + env(safe-area-inset-bottom));
  width: 100%;
  box-sizing: border-box;
}

.slot-grid.updating {
  opacity: 0.5;
}

.grid-message {
  width: 100%;
  flex: 0 0 100%;
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.slot {
  flex: 0 0 194rpx;
  width: 194rpx;
  max-width: 194rpx;
  min-width: 0;
  box-sizing: border-box;
  border: 1rpx solid #E9F0E8;
  padding: 24rpx 0;
  border-radius: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: rgba(45, 67, 57, 0.6);
  background: #F9FBF9;
}

.slot.available {
  border-color: #A7C4A0;
  color: #2D4339;
  background: #ffffff;
}

.slot.unavailable {
  opacity: 0.3;
  background: #E9F0E8;
  border-color: #E9F0E8;
}

.slot-time {
  font-weight: 600;
  line-height: 1.2;
}

.phone-modal,
.success-modal,
.confirm-modal,
.alert-modal,
.cancel-modal,
.progress-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 85%;
  max-width: 700rpx;
  background: #ffffff;
  border: 1rpx solid #E9F0E8;
  border-radius: 64rpx;
  padding: 60rpx 40rpx;
  z-index: 13000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.28s ease;
  box-sizing: border-box;
  box-shadow: 0 20rpx 80rpx -20rpx rgba(45, 67, 57, 0.15);
}

.phone-modal.show,
.success-modal.show,
.confirm-modal.show,
.alert-modal.show,
.cancel-modal.show,
.progress-modal.show {
  visibility: visible;
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.modal-input {
  width: 100%;
  padding: 28rpx;
  background: #F9FBF9;
  border: 1rpx solid #E9F0E8;
  border-radius: 32rpx;
  color: #2D4339;
  font-size: 28rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-sizing: border-box;
}

.error-msg {
  color: #ef4444;
  font-size: 26rpx;
  text-align: center;
  display: none;
  margin-bottom: 20rpx;
}

.error-msg.show,
.inline-error {
  display: block;
  color: #ef4444;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.btn-group,
.two-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.confirm-btn,
.cancel-btn,
.progress-query-btn {
  flex: 1;
  background: #2D6A4F;
  color: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(45, 106, 79, 0.18);
}

.confirm-btn.secondary,
.cancel-btn.muted {
  background: #E9F0E8;
  color: #2D4339;
  box-shadow: none;
}

.confirm-btn.single,
.close-progress {
  margin-top: 30rpx;
}

.success-modal {
  text-align: center;
  padding: 64rpx 40rpx 56rpx;
}

.success-icon {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #E8F5E9;
  color: #2D6A4F;
  font-size: 56rpx;
  line-height: 108rpx;
  margin: 0 auto 20rpx;
}

.success-title {
  font-size: 34rpx;
  color: #2D4339;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  font-weight: 700;
}

.success-block {
  margin: 0 0 24rpx;
}

.success-label,
.success-note {
  font-size: 24rpx;
  color: rgba(45, 67, 57, 0.55);
  margin-top: 8rpx;
}

.success-no {
  font-size: 68rpx;
  color: #2D6A4F;
  font-weight: 800;
  letter-spacing: 8rpx;
  line-height: 1.1;
}

.success-info {
  text-align: left;
  background: #F9FBF9;
  border: 1rpx solid #E9F0E8;
  border-radius: 32rpx;
  padding: 8rpx 28rpx;
  margin-bottom: 24rpx;
}

.success-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(233, 240, 232, 0.8);
  gap: 24rpx;
}

.success-row:last-child {
  border-bottom: none;
}

.success-row-stylist {
  align-items: center;
}

.success-row-label {
  flex-shrink: 0;
  font-size: 26rpx;
  color: rgba(45, 67, 57, 0.55);
}

.success-row-value {
  font-size: 28rpx;
  color: #2D4339;
  font-weight: 600;
  text-align: right;
}

.success-stylist {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  min-width: 0;
}

.success-stylist-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #E9F0E8;
}

.success-stylist-text {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 0;
}

.success-stylist-name {
  font-size: 28rpx;
  color: #2D4339;
  font-weight: 600;
  line-height: 1.3;
}

.success-stylist-rank {
  font-size: 22rpx;
  color: rgba(45, 67, 57, 0.55);
  margin-top: 4rpx;
  line-height: 1.3;
}

.alert-modal {
  text-align: center;
  padding: 72rpx 50rpx 60rpx;
}

.alert-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FEF3E2;
  color: #B45309;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 120rpx;
  margin: 0 auto 24rpx;
}

.alert-title {
  font-size: 34rpx;
  color: #2D4339;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
  font-weight: 700;
}

.alert-block {
  margin: 0 0 28rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  background: #F9FBF9;
  border: 1rpx solid #E9F0E8;
}

.alert-label,
.alert-date {
  font-size: 24rpx;
  color: rgba(45, 67, 57, 0.55);
}

.alert-date {
  margin-top: 12rpx;
}

.alert-no {
  font-size: 64rpx;
  color: #B45309;
  font-weight: 800;
  letter-spacing: 6rpx;
  margin-top: 8rpx;
}

.alert-message {
  font-size: 26rpx;
  color: rgba(45, 67, 57, 0.65);
  line-height: 1.6;
  margin-bottom: 8rpx;
  padding: 0 8rpx;
}

.modal-close {
  background: transparent;
  color: #666;
  font-size: 44rpx;
  top: 24rpx;
  right: 24rpx;
}

.modal-hint {
  text-align: center;
  color: rgba(45, 67, 57, 0.55);
  font-size: 24rpx;
  margin-bottom: 30rpx;
}

.confirm-info {
  background: #F9FBF9;
  border: 1rpx solid #E9F0E8;
  border-radius: 32rpx;
  padding: 8rpx 28rpx;
  margin-bottom: 36rpx;
}

.confirm-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(233, 240, 232, 0.8);
}

.confirm-row:last-child {
  border-bottom: none;
}

.confirm-label {
  font-size: 26rpx;
  color: rgba(45, 67, 57, 0.55);
}

.confirm-value {
  font-size: 28rpx;
  color: #2D4339;
  font-weight: 600;
}

.appointments-list,
.progress-list {
  max-height: 600rpx;
  margin-bottom: 30rpx;
}

.appointment-row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.active-row {
  border: 2rpx solid #A7C4A0;
  background: #ffffff;
}

.disabled-row {
  border: 1rpx solid #e5e7eb;
  background: #f8f9fa;
  opacity: 0.75;
}

.appointment-main {
  flex: 1;
  min-width: 0;
}

.appointment-title {
  font-size: 28rpx;
  color: #2D4339;
  font-weight: 600;
}

.appointment-sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.appointment-reason {
  font-size: 22rpx;
  color: #ef4444;
  margin-top: 8rpx;
}

.not-cancellable-title {
  margin: 30rpx 0 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e5e7eb;
  color: #94a3b8;
  font-size: 24rpx;
}

.progress-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #E9F0E8;
  border-radius: 32rpx;
  background: #F9FBF9;
}

.progress-title {
  font-weight: 600;
  color: #2D4339;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.progress-line {
  font-size: 26rpx;
  color: #2D6A4F;
  font-weight: 600;
  margin-top: 10rpx;
}

.progress-line.second {
  font-size: 25rpx;
}

.red-num {
  font-weight: 800;
  color: #c62828;
  font-size: 34rpx;
}

.red-num.small {
  font-size: 30rpx;
}
