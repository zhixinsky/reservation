.my-page {
  min-height: 100vh;
  padding-right: 28rpx;
  padding-bottom: calc(190rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
  padding-left: 28rpx;
  box-sizing: border-box;
  background: #F3F5F4;
  color: #2D4339;
}

.profile-card,
.stats-card,
.action-card {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(45, 67, 57, 0.06);
  margin-bottom: 24rpx;
}

.profile-card {
  padding: 60rpx 32rpx 56rpx;
  min-height: 220rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.profile-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.profile-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.profile-info {
  flex: 1;
  min-width: 0;
  padding-right: 8rpx;
}

.welcome-row {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 16rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1F2937;
  line-height: 1.3;
  flex-shrink: 0;
}

.admin-entry {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(45, 106, 79, 0.12);
  border: 1rpx solid rgba(45, 106, 79, 0.18);
  color: #2D6A4F;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.welcome-sub {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.45;
}

.logout-link {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(127, 169, 152, 0.12);
  border: 1rpx solid rgba(127, 169, 152, 0.16);
  font-size: 22rpx;
  font-weight: 600;
  color: #6B8F83;
  line-height: 1.2;
  white-space: nowrap;
}

.login-btn-wrap {
  flex: 0 0 auto;
  display: inline-flex;
}

.login-btn {
  margin: 0;
  padding: 12rpx 18rpx;
  min-width: 0 !important;
  width: auto !important;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #2D6A4F;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.stats-card {
  padding: 28rpx 24rpx 24rpx;
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.stats-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F2937;
}

.stats-grid {
  display: flex;
  align-items: stretch;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
  padding: 8rpx 0;
}

.stats-item:active {
  opacity: 0.72;
}

.stats-divider {
  width: 1rpx;
  background: #E9F0E8;
  margin: 8rpx 0;
}

.stats-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E8F3EE;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.stats-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 8rpx;
}

.stats-num {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F2937;
  line-height: 1;
}

.action-card {
  padding: 8rpx 0;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E8F3EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.action-text {
  flex: 1;
  min-width: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1F2937;
}

.action-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #94A3B8;
}

.action-arrow {
  color: #CBD5E1;
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.action-divider {
  height: 1rpx;
  margin: 0 32rpx;
  background: #EEF2F0;
}

.action-item-with-btn {
  position: relative;
  padding: 0;
}

.action-item-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
  pointer-events: none;
}

.action-item-cover-btn {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  width: 100%;
  height: 100%;
  min-width: 100%;
  min-height: 100%;
  margin: 0;
  padding: 0;
  background-color: transparent;
  border: none;
  border-radius: 0;
  line-height: normal;
}

.action-item-cover-btn::after {
  border: none;
}

.action-item-btn-hover {
  background-color: rgba(0, 0, 0, 0.03) !important;
}

.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 1000;
}

.detail-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 82vh;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.28s ease;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(45, 67, 57, 0.12);
}

.detail-panel.show {
  transform: translateY(0);
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #EEF2F0;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 800;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F3F4F6;
  color: #64748B;
  font-size: 36rpx;
  line-height: 56rpx;
  text-align: center;
}

.detail-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.detail-section {
  margin-bottom: 28rpx;
}

.detail-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.detail-section-head .detail-section-title {
  margin-bottom: 0;
}

.empty {
  color: #94a3b8;
  text-align: center;
  padding: 36rpx 0;
  font-size: 26rpx;
}

.appointment-card,
.history-row,
.progress-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #F9FBF9;
  border: 1rpx solid #E9F0E8;
  margin-bottom: 18rpx;
}

.appointment-card-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.appointment-main {
  flex: 1;
  min-width: 0;
}

.history-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.appointment-title {
  color: #2D4339;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.appointment-sub {
  color: #94a3b8;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.appointment-reason {
  margin-top: 14rpx;
  color: #ef4444;
  font-size: 24rpx;
  line-height: 1.4;
}

.compact-btn {
  flex-shrink: 0;
  width: auto;
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  background: #E8F5E9;
  color: #2D6A4F;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.compact-btn.danger {
  background: #FEF2F2;
  color: #dc2626;
}

.status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #64748b;
  background: #F1F5F9;
}

.status.booked,
.status.pending {
  color: #2D6A4F;
  background: #E8F5E9;
}

.status.completed {
  color: #2563eb;
  background: #EFF6FF;
}

.status.cancelled {
  color: #ef4444;
  background: #FEF2F2;
}

.progress-disclaimer {
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #F3F7F5;
  color: #7A8B83;
  font-size: 22rpx;
  line-height: 1.5;
}

.progress-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.progress-card-main {
  flex: 1;
  min-width: 0;
}

.progress-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.progress-status.normal {
  color: #2D6A4F;
  background: #E8F5E9;
}

.progress-status.slight {
  color: #B45309;
  background: #FEF3C7;
}

.progress-status.contact {
  color: #8A6B4D;
  background: #F3EDE7;
}

.progress-line {
  font-size: 26rpx;
  color: #2D4339;
  font-weight: 600;
  margin-top: 12rpx;
  line-height: 1.45;
}

.progress-line.second {
  font-size: 25rpx;
  color: #4F6459;
  font-weight: 500;
}

.queue-num {
  font-weight: 800;
  color: #2D6A4F;
  font-size: 32rpx;
}

.wait-range {
  font-weight: 700;
}

.wait-range.normal {
  color: #2D6A4F;
}

.wait-range.slight {
  color: #B45309;
}

.wait-range.contact {
  color: #8A6B4D;
}

.progress-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94A3B8;
  line-height: 1.45;
}
