.my-page {
  min-height: 100vh;
  padding-right: 28rpx;
  padding-bottom: calc(190rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
  padding-left: 28rpx;
  box-sizing: border-box;
  background: #F3F5F4;
  color: #2D4339;
}

.profile-card,
.booking-card-wrap,
.action-card {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(45, 67, 57, 0.06);
  margin-bottom: 24rpx;
}

.profile-card {
  padding: 60rpx 32rpx 56rpx;
  min-height: 220rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.profile-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.profile-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.profile-info {
  flex: 1;
  min-width: 0;
  padding-right: 8rpx;
}

.welcome-row {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 16rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1F2937;
  line-height: 1.3;
  flex-shrink: 0;
}

.admin-entry {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(45, 106, 79, 0.12);
  border: 1rpx solid rgba(45, 106, 79, 0.18);
  color: #2D6A4F;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.welcome-sub {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.45;
}

.logout-link {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(127, 169, 152, 0.12);
  border: 1rpx solid rgba(127, 169, 152, 0.16);
  font-size: 22rpx;
  font-weight: 600;
  color: #6B8F83;
  line-height: 1.2;
  white-space: nowrap;
}

.login-btn-wrap {
  flex: 0 0 auto;
  display: inline-flex;
}

.login-btn {
  margin: 0;
  padding: 12rpx 18rpx;
  min-width: 0 !important;
  width: auto !important;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #2D6A4F;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.booking-card-wrap {
  padding: 28rpx 24rpx 20rpx;
}

.booking-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.booking-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F2937;
}

.booking-tabs {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.booking-tab {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #F3F5F4;
  color: #64748B;
}

.booking-tab.active {
  background: #E8F5EE;
  color: #2D6A4F;
}

.tab-label {
  font-size: 24rpx;
  font-weight: 700;
}

.tab-count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(100, 116, 139, 0.12);
  color: inherit;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
}

.booking-tab.active .tab-count {
  background: rgba(45, 106, 79, 0.14);
}

.tab-indicator {
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  width: 36rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #2D6A4F;
  transform: translateX(-50%);
}

.booking-empty {
  color: #94A3B8;
  text-align: center;
  padding: 48rpx 0 32rpx;
  font-size: 26rpx;
}

.booking-list-scroll {
  width: 100%;
}

.booking-list-scroll.scrollable {
  box-sizing: border-box;
}

.booking-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.appt-bg-preload {
  position: absolute;
  width: 0;
  height: 0;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
}

.appt-card {
  position: relative;
  height: 280rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #eef6f1 0%, #f4faf7 100%);
}

.appt-card-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.appt-card-body {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.appt-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  width: 100%;
  flex-shrink: 0;
}

.appt-card-content {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.appt-card-main {
  flex: 1;
  min-width: 0;
  min-height: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 12rpx;
  padding-right: 16rpx;
}

.appt-status {
  display: inline-flex;
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.appt-store-capsule {
  flex-shrink: 0;
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 240rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 2rpx 8rpx rgba(17, 24, 39, 0.02);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.appt-store-capsule-name {
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(55, 65, 81, 0.62);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.appt-status.pending {
  color: #2D6A4F;
  background: rgba(255, 255, 255, 0.88);
}

.appt-status.completed {
  color: #2563eb;
  background: rgba(255, 255, 255, 0.88);
}

.appt-status.cancelled {
  color: #dc2626;
  background: rgba(255, 255, 255, 0.88);
}

.appt-datetime {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F4336;
  line-height: 1.35;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.85);
}

.appt-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.appt-appid {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.85);
}

.appt-service {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #2D4339;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.85);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.appt-stylist {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
}

.appt-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #E8F3EE;
  flex-shrink: 0;
}

.appt-avatar-img {
  width: 100%;
  height: 100%;
}

.appt-stylist-info {
  min-width: 0;
}

.appt-stylist-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1F2937;
  line-height: 1.3;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.85);
}

.appt-stylist-rank {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #64748B;
  line-height: 1.3;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.85);
}

.appt-detail-btn {
  align-self: flex-end;
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #2D6A4F;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  box-shadow: 0 8rpx 24rpx rgba(45, 67, 57, 0.08);
}

.appt-detail-btn:active {
  opacity: 0.82;
}

.booking-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #EEF2F0;
}

.booking-footer-left {
  font-size: 24rpx;
  color: #94A3B8;
}

.booking-footer-link {
  font-size: 24rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.action-card {
  padding: 8rpx 0;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E8F3EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.action-text {
  flex: 1;
  min-width: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1F2937;
}

.action-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #94A3B8;
}

.action-arrow {
  color: #CBD5E1;
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.action-divider {
  height: 1rpx;
  margin: 0 32rpx;
  background: #EEF2F0;
}

.action-item-with-btn {
  position: relative;
  padding: 0;
}

.action-item-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
  pointer-events: none;
}

.action-item-cover-btn {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  width: 100%;
  height: 100%;
  min-width: 100%;
  min-height: 100%;
  margin: 0;
  padding: 0;
  background-color: transparent;
  border: none;
  border-radius: 0;
  line-height: normal;
}

.action-item-cover-btn::after {
  border: none;
}

.action-item-btn-hover {
  background-color: rgba(0, 0, 0, 0.03) !important;
}

.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 1200;
}

.detail-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.92);
  width: calc(100% - 56rpx);
  max-width: 680rpx;
  max-height: 82vh;
  overflow-y: auto;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx 28rpx 36rpx;
  box-sizing: border-box;
  z-index: 1201;
  opacity: 0;
  visibility: hidden;
  transition: all 0.28s ease;
  box-shadow: 0 24rpx 80rpx rgba(45, 67, 57, 0.18);
}

.detail-modal.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.detail-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.detail-modal-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F2937;
}

.detail-modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F3F4F6;
  color: #64748B;
  font-size: 36rpx;
  line-height: 56rpx;
  text-align: center;
}

.detail-summary {
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #F4FAF7 0%, #EEF6F1 100%);
  border: 1rpx solid #E3EEE8;
  margin-bottom: 20rpx;
}

.detail-summary-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.detail-status {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-status.pending {
  color: #2D6A4F;
  background: rgba(255, 255, 255, 0.88);
}

.detail-datetime {
  font-size: 30rpx;
  font-weight: 800;
  color: #1F4336;
  line-height: 1.35;
}

.detail-meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.45;
}

.detail-meta-dot {
  color: #CBD5E1;
}

.detail-progress-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F9FBF9;
  border: 1rpx solid #E9F0E8;
  margin-bottom: 20rpx;
}

.detail-progress-card.normal {
  background: #F4FAF7;
  border-color: #D9EBE2;
}

.detail-progress-card.slight {
  background: #FFFBEB;
  border-color: #FDE68A;
}

.detail-progress-card.contact {
  background: #FAF6F2;
  border-color: #E8DDD2;
}

.detail-progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.detail-progress-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #1F2937;
}

.detail-progress-refresh {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #E8F5E9;
  color: #2D6A4F;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-progress-body {
  min-height: 204rpx;
}

.detail-progress-row {
  min-height: 40rpx;
}

.detail-progress-row.status-row {
  min-height: 52rpx;
  margin-bottom: 12rpx;
}

.detail-progress-row.line-row.second {
  margin-top: 8rpx;
}

.detail-progress-row.hint-row {
  min-height: 36rpx;
  margin-top: 12rpx;
}

.detail-progress-skeleton {
  border-radius: 8rpx;
  background: linear-gradient(90deg, #EEF2F6 25%, #F8FAFC 50%, #EEF2F6 75%);
  background-size: 200% 100%;
  animation: detail-progress-skeleton 1.2s ease-in-out infinite;
}

.detail-progress-skeleton-pill {
  width: 148rpx;
  height: 40rpx;
  border-radius: 999rpx;
}

.detail-progress-skeleton-line {
  width: 100%;
  height: 32rpx;
}

.detail-progress-skeleton-line.short {
  width: 72%;
}

.detail-progress-skeleton-line.hint {
  width: 88%;
  height: 28rpx;
}

@keyframes detail-progress-skeleton {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.detail-progress-status {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-progress-status.normal {
  color: #2D6A4F;
  background: #E8F5E9;
}

.detail-progress-status.slight {
  color: #B45309;
  background: #FEF3C7;
}

.detail-progress-status.contact {
  color: #8A6B4D;
  background: #F3EDE7;
}

.detail-progress-line {
  font-size: 26rpx;
  color: #2D4339;
  font-weight: 600;
  line-height: 1.5;
}

.detail-progress-line.second {
  font-size: 25rpx;
  font-weight: 500;
  color: #4F6459;
}

.detail-queue-num {
  font-weight: 800;
  color: #2D6A4F;
  font-size: 32rpx;
}

.detail-wait-range {
  font-weight: 700;
}

.detail-wait-range.normal {
  color: #2D6A4F;
}

.detail-wait-range.slight {
  color: #B45309;
}

.detail-wait-range.contact {
  color: #8A6B4D;
}

.detail-progress-hint {
  font-size: 22rpx;
  color: #94A3B8;
  line-height: 1.45;
}

.detail-reason {
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #FEF2F2;
  color: #dc2626;
  font-size: 24rpx;
  line-height: 1.45;
}

.detail-actions {
  margin-top: 4rpx;
}

.detail-cancel-btn {
  padding: 26rpx;
  border-radius: 24rpx;
  background: #FEF2F2;
  color: #dc2626;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.detail-cancel-btn:active {
  opacity: 0.86;
}

.detail-cancel-confirm {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.5;
  text-align: center;
}

.detail-actions-row {
  display: flex;
  gap: 16rpx;
}

.detail-action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.detail-action-btn.muted {
  background: #F3F4F6;
  color: #64748B;
}

.detail-action-btn.danger {
  background: #dc2626;
  color: #ffffff;
}
