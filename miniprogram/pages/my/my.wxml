<view class="my-page" style="padding-top: {{pagePaddingTop}}px;">
  <view class="profile-card">
    <image class="profile-bg" src="{{profileBgUrl}}" mode="aspectFill" lazy-load="{{false}}"></image>
    <view class="profile-top">
      <view class="profile-info">
        <view class="welcome-row">
          <view class="welcome-title">{{phone ? '欢迎回来' : '欢迎来到' + storeName}}</view>
          <view wx:if="{{phone && isAdmin}}" class="admin-entry" bindtap="openAdminDashboard">管理</view>
        </view>
        <view class="welcome-sub">{{phone ? ('已登录 ' + maskedPhone) : '登录后享受更便捷的预约服务'}}</view>
      </view>
      <view wx:if="{{!phone}}" class="login-btn-wrap">
        <button class="login-btn" size="mini" open-type="getPhoneNumber" bindgetphonenumber="onPhoneNumber">手机号快速登录</button>
      </view>
      <view wx:if="{{phone}}" class="logout-link" bindtap="logout">退出登录</view>
    </view>
  </view>

  <view class="booking-card-wrap">
    <view class="booking-header">
      <view class="booking-title">我的预约</view>
    </view>

    <view class="booking-tabs">
      <view
        class="booking-tab {{appointmentTab === 'pendingService' ? 'active' : ''}}"
        bindtap="switchAppointmentTab"
        data-tab="pendingService"
      >
        <text class="tab-label">待服务</text>
        <text class="tab-count">{{stats.pendingService}}</text>
        <view wx:if="{{appointmentTab === 'pendingService'}}" class="tab-indicator"></view>
      </view>
      <view
        class="booking-tab {{appointmentTab === 'completed' ? 'active' : ''}}"
        bindtap="switchAppointmentTab"
        data-tab="completed"
      >
        <text class="tab-label">已完成</text>
        <text class="tab-count">{{stats.completed}}</text>
        <view wx:if="{{appointmentTab === 'completed'}}" class="tab-indicator"></view>
      </view>
      <view
        class="booking-tab {{appointmentTab === 'cancelled' ? 'active' : ''}}"
        bindtap="switchAppointmentTab"
        data-tab="cancelled"
      >
        <text class="tab-label">已取消</text>
        <text class="tab-count">{{stats.cancelled}}</text>
        <view wx:if="{{appointmentTab === 'cancelled'}}" class="tab-indicator"></view>
      </view>
    </view>

    <view wx:if="{{!phone}}" class="booking-empty">请先手机号快速登录</view>
    <view wx:elif="{{displayList.length === 0}}" class="booking-empty">暂无{{tabLabel}}记录</view>
    <scroll-view
      wx:else
      class="booking-list-scroll {{bookingListScrollable ? 'scrollable' : ''}}"
      scroll-y="{{bookingListScrollable}}"
      enhanced
      show-scrollbar="{{false}}"
      style="{{bookingListMaxHeight ? 'max-height:' + bookingListMaxHeight + 'px' : ''}}"
    >
      <view class="booking-list">
      <view wx:for="{{displayList}}" wx:key="id" id="{{index === 0 ? 'bookingApptCard' : ''}}" class="appt-card">
        <image class="appt-card-bg" src="{{item.cardBgUrl}}" mode="widthFix"></image>
        <view class="appt-card-body">
          <view class="appt-card-header">
            <view class="appt-status {{item.statusClass}}">{{item.cardStatusText}}</view>
            <view wx:if="{{item.storeName}}" class="appt-store-capsule">
              <text class="appt-store-capsule-name">{{item.storeName}}</text>
            </view>
          </view>
          <view class="appt-card-content">
            <view class="appt-card-main">
              <view class="appt-datetime">{{item.dateCardText}} {{item.weekdayText}} {{item.timeDisplay}}</view>
              <view class="appt-meta">
                <text class="appt-appid">预约号：{{item.appId}}</text>
                <text class="appt-service">{{item.serviceDesc}}</text>
              </view>
              <view class="appt-stylist">
                <view class="appt-avatar">
                  <image class="appt-avatar-img" src="{{item.stylistAvatar}}" mode="aspectFill"></image>
                </view>
                <view class="appt-stylist-info">
                  <view class="appt-stylist-name">{{item.stylistName}}</view>
                  <view wx:if="{{item.stylistRank}}" class="appt-stylist-rank">{{item.stylistRank}}</view>
                </view>
              </view>
            </view>
            <view
              wx:if="{{appointmentTab === 'pendingService'}}"
              class="appt-detail-btn"
              bindtap="viewAppointmentDetail"
              data-id="{{item.id}}"
            >查看详情 ›</view>
          </view>
        </view>
      </view>
      </view>
    </scroll-view>

    <view class="booking-footer">
      <view class="booking-footer-left">{{displayList.length > 0 ? '没有更多预约了' : '暂无预约记录'}}</view>
      <view class="booking-footer-link" bindtap="goToBooking">去预约 ›</view>
    </view>
  </view>

  <view wx:if="{{detailVisible}}" class="detail-mask" bindtap="closeDetail"></view>
  <view class="detail-modal {{detailVisible ? 'show' : ''}}">
    <view class="detail-modal-header">
      <view class="detail-modal-title">预约详情</view>
      <view class="detail-modal-close" bindtap="closeDetail">×</view>
    </view>

    <view wx:if="{{detailAppointment}}" class="detail-summary">
      <view class="detail-summary-top">
        <view class="detail-status pending">待服务</view>
        <view class="detail-datetime">{{detailAppointment.dateCardText}} {{detailAppointment.weekdayText}} {{detailAppointment.timeDisplay}}</view>
      </view>
      <view class="detail-meta-row">
        <text>预约号 {{detailAppointment.appId}}</text>
        <text class="detail-meta-dot">·</text>
        <text>{{detailAppointment.serviceDesc}}</text>
      </view>
    </view>

    <view class="detail-progress-card {{detailProgress.statusLevel || ''}}">
      <view class="detail-progress-head">
        <view class="detail-progress-label">排队进度</view>
        <view class="detail-progress-refresh" bindtap="refreshDetailProgress">刷新</view>
      </view>
      <view class="detail-progress-body">
        <view class="detail-progress-row status-row">
          <view wx:if="{{detailLoading}}" class="detail-progress-skeleton detail-progress-skeleton-pill"></view>
          <view
            wx:elif="{{detailProgress && detailProgress.showStatus}}"
            class="detail-progress-status {{detailProgress.statusLevel}}"
          >{{detailProgress.statusText}}</view>
        </view>
        <view class="detail-progress-row line-row">
          <view wx:if="{{detailLoading}}" class="detail-progress-skeleton detail-progress-skeleton-line"></view>
          <view wx:elif="{{detailProgress}}" class="detail-progress-line">
            <block wx:if="{{detailProgress.hasAheadCount}}">您前面约有<text class="detail-queue-num">{{detailProgress.aheadCount}}</text>单待完成</block>
            <block wx:else>{{detailProgress.delayLine1}}</block>
          </view>
        </view>
        <view class="detail-progress-row line-row second">
          <view wx:if="{{detailLoading}}" class="detail-progress-skeleton detail-progress-skeleton-line short"></view>
          <view wx:elif="{{detailProgress && detailProgress.delayLine2}}" class="detail-progress-line second">
            <text>{{detailProgress.delayLine2}}</text><text wx:if="{{detailProgress.numberPart}}" class="detail-wait-range {{detailProgress.statusLevel}}">{{detailProgress.numberPart}}</text>
          </view>
        </view>
        <view class="detail-progress-row hint-row">
          <view wx:if="{{detailLoading}}" class="detail-progress-skeleton detail-progress-skeleton-line hint"></view>
          <view wx:elif="{{detailProgress && detailProgress.showHint}}" class="detail-progress-hint">排队信息仅供参考，请以商家现场进度为准</view>
        </view>
      </view>
    </view>

    <view wx:if="{{detailAppointment && detailAppointment.reason}}" class="detail-reason">{{detailAppointment.reason}}</view>

    <view wx:if="{{detailAppointment && detailAppointment.canCancel}}" class="detail-actions">
      <block wx:if="{{!cancelConfirmVisible}}">
        <view class="detail-cancel-btn" bindtap="showCancelConfirm">取消预约</view>
      </block>
      <block wx:else>
        <view class="detail-cancel-confirm">确定取消该预约吗？取消后名额将释放给其他顾客。</view>
        <view class="detail-actions-row">
          <view class="detail-action-btn muted" bindtap="hideCancelConfirm">再想想</view>
          <view class="detail-action-btn danger" bindtap="confirmDetailCancel">确认取消</view>
        </view>
      </block>
    </view>
  </view>

  <view class="action-card">
    <view class="action-item" bindtap="openStoreNavigation">
      <view class="action-icon-wrap">
        <image class="action-icon-img" src="/images/action-navigation.svg" mode="aspectFit"></image>
      </view>
      <view class="action-text">
        <view class="action-title">门店导航</view>
        <view class="action-sub">查看门店位置及路线</view>
      </view>
      <text class="action-arrow">›</text>
    </view>
    <view class="action-divider"></view>
    <view class="action-item" bindtap="contactService">
      <view class="action-icon-wrap">
        <image class="action-icon-img" src="/images/action-service.svg" mode="aspectFit"></image>
      </view>
      <view class="action-text">
        <view class="action-title">联系商家</view>
        <view class="action-sub">有问题随时为您解答</view>
      </view>
      <text class="action-arrow">›</text>
    </view>
    <view class="action-divider"></view>
    <view class="action-item action-item-with-btn">
      <button
        class="action-item-cover-btn"
        open-type="contact"
        session-from="我的页-反馈建议"
        hover-class="action-item-btn-hover"
      ></button>
      <view class="action-item-content">
        <view class="action-icon-wrap">
          <image class="action-icon-img" src="/images/action-feedback.svg" mode="aspectFit"></image>
        </view>
        <view class="action-text">
          <view class="action-title">反馈建议</view>
          <view class="action-sub">直接向开发者反馈问题与建议</view>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>
</view>
