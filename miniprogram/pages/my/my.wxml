<view class="my-page" style="padding-top: {{pagePaddingTop}}px;">
  <view class="profile-card">
    <image class="profile-bg" src="{{profileBgUrl}}" mode="aspectFill" lazy-load="{{false}}"></image>
    <view class="profile-top">
      <view class="profile-info">
        <view class="welcome-row">
          <view class="welcome-title">{{phone ? '欢迎回来' : '欢迎来到欧诺造型'}}</view>
          <view wx:if="{{phone && isAdmin}}" class="admin-entry" bindtap="openAdminDashboard">管理</view>
        </view>
        <view class="welcome-sub">{{phone ? ('已登录 ' + maskedPhone) : '登录后享受更便捷的预约服务'}}</view>
      </view>
      <view wx:if="{{!phone}}" class="login-btn-wrap">
        <button class="login-btn" size="mini" open-type="getPhoneNumber" bindgetphonenumber="onPhoneNumber">手机号快速登录</button>
      </view>
      <view wx:if="{{phone}}" class="logout-link" bindtap="logout">退出登录</view>
    </view>
  </view>

  <view class="stats-card">
    <view class="stats-header">
      <view class="stats-title">我的预约</view>
    </view>
    <view class="stats-grid">
      <view class="stats-item" bindtap="openStatsDetail" data-type="pendingService">
        <view class="stats-icon-wrap">
          <image class="stats-icon-img" src="/images/stats-pending.svg" mode="aspectFit"></image>
        </view>
        <view class="stats-label">待服务</view>
        <view class="stats-num">{{stats.pendingService}}</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="openStatsDetail" data-type="completed">
        <view class="stats-icon-wrap">
          <image class="stats-icon-img" src="/images/stats-completed.svg" mode="aspectFit"></image>
        </view>
        <view class="stats-label">已完成</view>
        <view class="stats-num">{{stats.completed}}</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="openStatsDetail" data-type="cancelled">
        <view class="stats-icon-wrap">
          <image class="stats-icon-img" src="/images/stats-cancelled.svg" mode="aspectFit"></image>
        </view>
        <view class="stats-label">已取消</view>
        <view class="stats-num">{{stats.cancelled}}</view>
      </view>
    </view>
  </view>

  <view class="action-card">
    <view class="action-item" bindtap="openStoreNavigation">
      <view class="action-icon-wrap">
        <image class="action-icon-img" src="/images/action-navigation.svg" mode="aspectFit"></image>
      </view>
      <view class="action-text">
        <view class="action-title">门店导航</view>
        <view class="action-sub">查看门店位置及路线</view>
      </view>
      <text class="action-arrow">›</text>
    </view>
    <view class="action-divider"></view>
    <view class="action-item" bindtap="contactService">
      <view class="action-icon-wrap">
        <image class="action-icon-img" src="/images/action-service.svg" mode="aspectFit"></image>
      </view>
      <view class="action-text">
        <view class="action-title">联系商家</view>
        <view class="action-sub">有问题随时为您解答</view>
      </view>
      <text class="action-arrow">›</text>
    </view>
    <view class="action-divider"></view>
    <view class="action-item action-item-with-btn">
      <view class="action-icon-wrap">
        <image class="action-icon-img" src="/images/action-feedback.svg" mode="aspectFit"></image>
      </view>
      <view class="action-text">
        <view class="action-title">反馈建议</view>
        <view class="action-sub">在线客服，倾听您的意见</view>
      </view>
      <text class="action-arrow">›</text>
      <button
        class="action-item-cover-btn"
        open-type="contact"
        session-from="我的页-反馈建议"
        hover-class="none"
      ></button>
    </view>
  </view>

  <view wx:if="{{detailVisible}}" class="detail-mask" bindtap="closeAllAppointments"></view>
  <view class="detail-panel {{detailVisible ? 'show' : ''}}">
    <view class="detail-header">
      <view class="detail-title">{{detailTitle}}</view>
      <view class="detail-close" bindtap="closeAllAppointments">×</view>
    </view>

    <scroll-view class="detail-scroll" scroll-y>
      <view class="detail-section">
        <view wx:if="{{!phone}}" class="empty">请先手机号快速登录</view>
        <view wx:elif="{{detailList.length === 0}}" class="empty">暂无{{detailTitle}}记录</view>
        <block wx:elif="{{detailFilter === 'pendingService'}}">
          <view wx:for="{{detailList}}" wx:key="id" class="appointment-card">
            <view class="appointment-card-row">
              <view class="appointment-main">
                <view class="appointment-title">{{item.dateText}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
                <view class="appointment-sub">预约号: {{item.appId}}</view>
                <view class="appointment-sub">状态: {{item.statusText}}</view>
              </view>
              <view wx:if="{{item.canCancel}}" class="compact-btn danger" bindtap="cancelOne" data-id="{{item.id}}">取消预约</view>
            </view>
            <view wx:if="{{item.reason}}" class="appointment-reason">{{item.reason}}</view>
          </view>
        </block>
        <block wx:else>
          <view wx:for="{{detailList}}" wx:key="id" class="history-row">
            <view>
              <view class="appointment-title">{{item.dateText}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
              <view class="appointment-sub">预约号: {{item.appId}}</view>
            </view>
            <text class="status {{item.status}}">{{item.statusText}}</text>
          </view>
        </block>
      </view>

      <view wx:if="{{detailFilter === 'pendingService' && detailList.length > 0}}" class="detail-section">
        <view class="detail-section-head">
          <view class="detail-section-title">排队信息</view>
          <view class="compact-btn" bindtap="loadProgress">刷新</view>
        </view>
        <view class="progress-disclaimer">排队信息仅供参考，每单服务时长不固定，请以商家现场进度为准。</view>
        <view wx:if="{{progressRows.length === 0}}" class="empty">暂无排队信息</view>
        <view wx:for="{{progressRows}}" wx:key="key" class="progress-card {{item.statusLevel}}">
          <view class="progress-card-top">
            <view class="progress-card-main">
              <view class="appointment-title">{{item.dateStr}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
              <view class="appointment-sub">预约号: {{item.appId}}</view>
            </view>
            <view wx:if="{{item.showStatus}}" class="progress-status {{item.statusLevel}}">{{item.statusText}}</view>
          </view>
          <view class="progress-line">
            <block wx:if="{{item.hasAheadCount}}">您前面约有<text class="queue-num"> {{item.aheadCount}} </text>单待完成</block>
            <block wx:else>{{item.delayLine1}}</block>
          </view>
          <view wx:if="{{item.delayLine2}}" class="progress-line second">
            <text>{{item.delayLine2}}</text><text wx:if="{{item.numberPart}}" class="wait-range {{item.statusLevel}}"> {{item.numberPart}}</text>
          </view>
          <view wx:if="{{item.showHint}}" class="progress-hint">实际等待以服务进度为准，不确定请联系商家</view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
