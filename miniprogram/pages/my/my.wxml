<view class="my-page">
  <view class="hero">
    <view>
      <view class="title">我的预约</view>
      <view class="subtitle">{{subtitleText}}</view>
    </view>
    <button wx:if="{{!phone}}" class="auth-btn" open-type="getPhoneNumber" bindgetphonenumber="onPhoneNumber">手机号快速验证</button>
    <button wx:else class="refresh-btn" bindtap="loadData">刷新</button>
  </view>

  <view wx:if="{{phone}}" class="section">
    <view class="section-title">当前预约</view>
    <view wx:if="{{currentAppointments.length === 0}}" class="empty">暂无当前预约</view>
    <view wx:for="{{currentAppointments}}" wx:key="id" class="appointment-card">
      <view class="appointment-title">{{item.dateText}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
      <view class="appointment-sub">预约号: {{item.appId}}</view>
      <view wx:if="{{item.reason}}" class="appointment-reason">{{item.reason}}</view>
      <button wx:if="{{item.canCancel}}" class="cancel-btn" bindtap="cancelOne" data-id="{{item.id}}">取消预约</button>
    </view>
  </view>

  <view wx:if="{{phone}}" class="section">
    <view class="section-header">
      <view class="section-title compact">排队查询</view>
      <button class="mini-btn" bindtap="loadProgress">刷新</button>
    </view>
    <view wx:if="{{progressRows.length === 0}}" class="empty">暂无排队信息</view>
    <view wx:for="{{progressRows}}" wx:key="key" class="progress-card">
      <view class="appointment-title">{{item.dateStr}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
      <view class="appointment-sub">预约号: {{item.appId}}</view>
      <view class="progress-line">
        <block wx:if="{{item.hasAheadCount}}">您前面还有<text class="red-num"> {{item.aheadCount}} </text>位已预约未完成的客户</block>
        <block wx:else>{{item.delayLine1}}</block>
      </view>
      <view wx:if="{{item.delayLine2}}" class="progress-line second">
        <text>{{item.delayLine2}}</text><text wx:if="{{item.numberPart}}" class="red-num small"> {{item.numberPart}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{phone}}" class="section">
    <view class="section-title">预约记录</view>
    <view wx:if="{{historyAppointments.length === 0}}" class="empty">暂无预约记录</view>
    <view wx:for="{{historyAppointments}}" wx:key="id" class="history-row">
      <view>
        <view class="appointment-title">{{item.dateText}} {{item.timeDisplay}} - {{item.serviceTypeText}}</view>
        <view class="appointment-sub">预约号: {{item.appId}}</view>
      </view>
      <text class="status {{item.status}}">{{item.statusText}}</text>
    </view>
  </view>
</view>
