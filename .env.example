# 本地开发：复制为 .env 并填写真实值（勿提交 .env）
# 云托管：见 docs/cloud-hosting-env.md

# ========== 必填 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

MYSQL_ADDRESS=127.0.0.1:3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_DATABASE=reservation_system

WX_APPSECRET=

# ========== 建议 ==========
WX_APPID=wxb76bea40dcb2999b
MINI_PROGRAM_URL=https://wxaurl.cn/byRtNK8KNSc
MYSQL_CONNECTION_LIMIT=10

# ========== 短信（可选）==========
EMAY_APPID=
EMAY_SECRETKEY=
EMAY_AUTO_CREATE_TEMPLATES=false
EMAY_TEMPLATE_ID_BOOKING=
EMAY_TEMPLATE_ID_CANCEL=
EMAY_TEMPLATE_ID_REMINDER=
EMAY_TEMPLATE_ID_STYLIST_CANCEL=   # 门店/发型师取消；未配置时回退 EMAY_TEMPLATE_ID_CANCEL

# ========== 门店小程序码（可选）==========
WX_QRCODE_ENV_VERSION=release

# ========== 仅云函数同步（纯云托管可忽略）==========
# TCB_ENV_ID=
# CLOUD_FUNCTION_NAME=api
# PLATFORM_SYNC_SECRET=   # 平台「同步到云开发」密钥（与云函数一致）
# TCB_ENV_ID=reservation-d2gf73dgv8fd17503  # 云托管环境 ID；发型师头像上传到对象存储 avatar/ 目录
# 云托管控制台需为微信令牌开通 /tcb/uploadfile 与 /tcb/batchdownloadfile 权限

# ========== 微信开放接口（二选一，见文档）==========
# WX_USE_OPENAPI=1

# ========== 首次无门店时的种子数据（可选）==========
# STORE_NAME=欧诺造型
# STORE_CODE=ounuo-main
# STORE_ADDRESS=
# STORE_PHONE=
# STORE_LATITUDE=
# STORE_LONGITUDE=
# DEFAULT_ANNOUNCEMENT=

# ========== 门店背景图 WebP 转换（生产建议配置）==========
# TINIFY_API_KEY=   # https://tinypng.com/developers 注册获取；上传背景图时压缩并转为 WebP
# TINIFY_PROXY=     # 可选 HTTP 代理

# ========== 本地开发 ==========
# PORT=3000
# AVATAR_LOCAL_FALLBACK=1  # 本地无云存储时回退 public/avatar、public/img；未配置 TINIFY_API_KEY 时背景图回退 JPEG
